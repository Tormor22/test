{
  "name": "agent-hr-manager",
  "version": "0.1.0",
  "description": "Agent HR Manager / Agent Workforce Manager — monitors, evaluates, warns, terminates, replaces, recruits and onboards every AI agent in the AgentOps platform.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-hr": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo": "tsx src/demo/runHrCycle.ts",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai-agent",
    "hr-manager",
    "workforce-manager",
    "supervisor",
    "agentops",
    "monitoring",
    "replacement",
    "probation",
    "telegram",
    "observability"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "optionalDependencies": {
    "ioredis": "^5.4.1",
    "pg": "^8.12.0"
  }
}
