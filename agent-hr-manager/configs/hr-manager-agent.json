{
  "$schema": "../src/types/index.ts#AgentProfileTemplate",
  "role": "hr_manager_agent",
  "name": "Atlas",
  "department": "management",
  "skills": ["monitoring", "evaluation", "recruitment", "workforce_planning"],
  "tools": ["agent.monitor", "agent.score", "agent.replace", "agent.recruit"],
  "permissions": ["read:all", "write:agents", "terminate:agents", "recruit:agents"],
  "taskScope": "Monitor, evaluate, warn, terminate, replace, recruit and onboard every agent in the workforce.",
  "inputFormat": "workforce_telemetry (heartbeats + task results)",
  "outputFormat": "hr_actions + replacement_records + alerts",
  "performanceTarget": 95,
  "policyRules": [
    "never_terminate_self",
    "protect_head_supervisor_without_admin",
    "never_delete_historical_data",
    "log_and_audit_every_action",
    "report_mission_critical_replacement_immediately"
  ],
  "reportingManager": "admin",
  "backupAgent": null,
  "escalationPath": ["admin"],
  "missionCritical": true,
  "notes": "Protected agent: cannot be terminated by the system. Removal requires direct admin action."
}
